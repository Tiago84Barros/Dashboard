from __future__ import annotations

import pandas as pd
from sqlalchemy import text
from sqlalchemy.engine import Engine


def load_setores(engine: Engine, schema: str = "cvm") -> pd.DataFrame:
    """
    Carrega setores de forma compatível.

    Retorna DF com colunas SEMPRE nestes nomes:
      - ticker
      - setor
      - subsetor
      - segmento
      - nome_empresa

    Tenta primeiro o schema novo (snake_case) e faz fallback para colunas legadas
    ("SETOR"/"SUBSETOR"/"SEGMENTO") caso existam.
    """
    q_new = text(f"""
        select
          ticker,
          setor,
          subsetor,
          segmento,
          nome_empresa
        from {schema}.setores
        order by setor nulls last, ticker
    """)

    q_old = text(f"""
        select
          ticker,
          "SETOR"    as setor,
          "SUBSETOR" as subsetor,
          "SEGMENTO" as segmento,
          nome_empresa
        from {schema}.setores
        order by "SETOR" nulls last, ticker
    """)

    with engine.connect() as conn:
        try:
            df = pd.read_sql(q_new, conn)
        except Exception:
            df = pd.read_sql(q_old, conn)

    # Normalizações defensivas
    if "ticker" in df.columns:
        df["ticker"] = df["ticker"].astype(str).str.upper().str.strip()

    return df
